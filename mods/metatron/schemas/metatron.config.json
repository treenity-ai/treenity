{
  "type": "object",
  "properties": {
    "model": {
      "type": "string",
      "default": "claude-opus-4-6"
    },
    "systemPrompt": {
      "type": "string",
      "format": "textarea",
      "default": ""
    },
    "sessionId": {
      "type": "string",
      "default": ""
    },
    "lastRun": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "model",
    "systemPrompt",
    "sessionId",
    "lastRun"
  ],
  "$id": "metatron.config",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "methods": {
    "task": {
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "prompt": {
              "type": "string"
            }
          },
          "required": [
            "prompt"
          ]
        }
      ]
    }
  }
}
