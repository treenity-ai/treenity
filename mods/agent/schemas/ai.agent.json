{
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "title": "Open-ended role string. Guardian policies keyed by role.",
      "default": "qa"
    },
    "status": {
      "default": "offline"
    },
    "currentTask": {
      "type": "string",
      "title": "Path to current board.task being worked on",
      "default": ""
    },
    "taskRef": {
      "type": "string",
      "title": "Path to current metatron.task (live log)",
      "default": ""
    },
    "lastRunAt": {
      "type": "number",
      "default": 0
    },
    "totalTokens": {
      "type": "number",
      "title": "Total tokens used across all tasks",
      "default": 0
    }
  },
  "required": [
    "role",
    "status",
    "currentTask",
    "taskRef",
    "lastRunAt",
    "totalTokens"
  ],
  "methods": {
    "online": {
      "description": "Bring agent online",
      "arguments": []
    },
    "offline": {
      "description": "Take agent offline",
      "arguments": []
    },
    "assign": {
      "description": "Assign a board task to this agent",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "task": {
              "type": "string",
              "title": "Path to board.task"
            }
          },
          "required": [
            "task"
          ]
        }
      ]
    },
    "complete": {
      "description": "Agent finished current task",
      "arguments": []
    },
    "block": {
      "description": "Agent is blocked",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "reason": {
              "type": "string",
              "title": "Reason"
            }
          }
        }
      ]
    },
    "fail": {
      "description": "Agent hit an error",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "title": "Error message"
            }
          }
        }
      ]
    }
  },
  "$id": "ai.agent",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
