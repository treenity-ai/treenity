            "role": {
              "type": "string"
            },
            "from": {
              "type": "string"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "role",
            "from",
            "text"
          ]
        }
      ]
    }
  },
  "$id": "ai.thread",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
