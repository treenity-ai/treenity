{
  "name": "@treenity/recall",
  "version": "1.0.0",
  "description": "Claude Code session transcript search — BM25 + vector hybrid RAG",
  "type": "module",
  "publishConfig": { "access": "public" },
  "license": "FSL-1.1-MIT",
  "author": "Treenity <hello@treenity.ai> (https://treenity.ai)",
  "homepage": "https://github.com/treenity-ai/treenity",
  "repository": {
    "type": "git",
    "url": "https://github.com/treenity-ai/treenity.git",
    "directory": "packages/recall"
  },
  "keywords": ["treenity", "recall", "search", "rag", "bm25", "transcripts"],
  "imports": {
    "#*": {
      "development": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@orama/orama": "^3.1.18"
  }
}
